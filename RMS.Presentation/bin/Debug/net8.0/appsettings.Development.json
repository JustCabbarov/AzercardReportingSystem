{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "PostgreSqlConnection": "Host=localhost;Port=5433;Database=AzercardDB;Username=AzercardDBUser;Password=secret123",
    "OracleConnection": "User Id=ali_jabbarov;Password=Alm@3d#9@$#ngd(;Data Source=172.25.43.25/DB_UAT;Connection Timeout=60;Pooling=false;"

  },
  "ModelStore": {
    "BasePath": "models"
  },
  "ForecastTraining": {
    "RunAtHour": 2,
    "RunAtMinute": 30
  },
  "JwtSettings": {
    "SecretKey": "your-super-secret-key-min-32-characters!",
    "Issuer": "RMS.API",
    "Audience": "RMS.Client",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Npgsql": "Error",
        "Microsoft.EntityFrameworkCore": "Error"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "restrictedToMinimumLevel": "Information",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss}] [{Level:u3}] {Message:lj}{NewLine}"
        }
      },
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss}] [{Level:u3}] {Message:lj}{NewLine}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ],
    "Properties": {
      "Application": "TaskManager"
    }

  }
}
